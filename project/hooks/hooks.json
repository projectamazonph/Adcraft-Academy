{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "name": "file-protector",
            "command": "${extensionPath}/hooks/file-protector.py",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "name": "git-guardrails",
            "command": "${extensionPath}/hooks/git-guardrails.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "sequential": true,
        "hooks": [
          {
            "type": "command",
            "name": "smart-lint",
            "command": "${extensionPath}/hooks/smart-lint.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "session-start",
            "command": "${extensionPath}/hooks/session-start.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "skill-enforcer",
            "command": "${extensionPath}/hooks/skill-enforcer.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "test-runner",
            "command": "${extensionPath}/hooks/test-runner.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "notify",
            "command": "${extensionPath}/hooks/notify.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
